{
  "name": "beffa-automation",
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "test:full": "npx playwright test",
    "test:ordered": "npm run clean && npx playwright test --project=Inventory && npx playwright test --project=Purchases && npx playwright test --project=Sales",
    "clean": "rm -rf test-results/ allure-results/ recordings/ artifacts/",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "report:allure": "npm run allure:generate && npx allure open allure-report"
  },
  "keywords": [],
  "author": "Tekleab",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "allure-playwright": "^3.6.0",
    "allure-commandline": "^2.38.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
